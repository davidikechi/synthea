{
  "name": "AML Disease Model",
  "remarks": [
    "Full AML disease model covering WHO-HAEM5 / ELN-2022 subtypes, diagnostic workup",
    "(karyotype, FISH, NGS, RT-PCR, flow cytometry, bone marrow biopsy), CBC and chemistry",
    "labs, subtype-specific induction and targeted therapies, APL-specific ATRA/ATO,",
    "supportive-care medications, oncologic complications, genomic alterations, and MRD",
    "response assessment.",
    "",
    "Subtype prevalence approximated from SEER / published literature:",
    "  NPM1-mutated AML         ~27%",
    "  FLT3-ITD AML             ~25%",
    "  CBF AML (RUNX1::RUNX1T1) ~ 8%",
    "  APL (PML::RARA)          ~10%",
    "  IDH1/IDH2-mutated AML    ~10%",
    "  TP53 / MDS-related AML   ~20%",
    "",
    "Incidence gate: 0.2% females, 0.3% males (ACS 2022), consistent with",
    "acute_myeloid_leukemia.json.  Onset distributed across ages 0-21 years.",
    "",
    "Ontology systems used: SNOMED-CT, LOINC, RxNorm, NUBC.",
    "",
    "FIXES applied:",
    "  - reason fields on Encounter/Procedure/MedicationOrder now reference the",
    "    ConditionOnset STATE NAME (AML_Condition_Onset) not the attribute name.",
    "  - ConditionEnd states use condition_onset: STATE NAME (e.g. Febrile_Neutropenia_Onset).",
    "  - All MedicationOrder states have assign_to_attribute for tracking.",
    "  - MedicationEnd states added for every MedicationOrder.",
    "  - RxNorm codes are integers as required by Synthea."
  ],
  "gmf_version": 2,
  "states": {

    "Initial": {
      "type": "Initial",
      "remarks": ["Gate on gender-specific AML incidence before assigning onset delay."],
      "complex_transition": [
        {
          "condition": {
            "condition_type": "Gender",
            "gender": "F"
          },
          "distributions": [
            { "transition": "Cancerous", "distribution": 0.002 },
            { "transition": "Terminal",  "distribution": 0.998 }
          ]
        },
        {
          "condition": {
            "condition_type": "Gender",
            "gender": "M"
          },
          "distributions": [
            { "transition": "Cancerous", "distribution": 0.003 },
            { "transition": "Terminal",  "distribution": 0.997 }
          ]
        }
      ]
    },

    "Cancerous": {
      "type": "Simple",
      "remarks": ["Distribute AML onset uniformly across ages 0-21 (years of delay)."],
      "distributed_transition": [
        { "transition": "Delay_0",  "distribution": 0.0455 },
        { "transition": "Delay_1",  "distribution": 0.0455 },
        { "transition": "Delay_2",  "distribution": 0.0455 },
        { "transition": "Delay_3",  "distribution": 0.0455 },
        { "transition": "Delay_4",  "distribution": 0.0455 },
        { "transition": "Delay_5",  "distribution": 0.0455 },
        { "transition": "Delay_6",  "distribution": 0.0455 },
        { "transition": "Delay_7",  "distribution": 0.0455 },
        { "transition": "Delay_8",  "distribution": 0.0455 },
        { "transition": "Delay_9",  "distribution": 0.0455 },
        { "transition": "Delay_10", "distribution": 0.0455 },
        { "transition": "Delay_11", "distribution": 0.0455 },
        { "transition": "Delay_12", "distribution": 0.0455 },
        { "transition": "Delay_13", "distribution": 0.0455 },
        { "transition": "Delay_14", "distribution": 0.0455 },
        { "transition": "Delay_15", "distribution": 0.0455 },
        { "transition": "Delay_16", "distribution": 0.0455 },
        { "transition": "Delay_17", "distribution": 0.0455 },
        { "transition": "Delay_18", "distribution": 0.0455 },
        { "transition": "Delay_19", "distribution": 0.0455 },
        { "transition": "Delay_20", "distribution": 0.0455 },
        { "transition": "Delay_21", "distribution": 0.0445 }
      ]
    },

    "Delay_0":  { "type": "Delay", "exact": { "quantity": 0,  "unit": "years" }, "direct_transition": "Assign_AML_Subtype" },
    "Delay_1":  { "type": "Delay", "exact": { "quantity": 1,  "unit": "years" }, "direct_transition": "Assign_AML_Subtype" },
    "Delay_2":  { "type": "Delay", "exact": { "quantity": 2,  "unit": "years" }, "direct_transition": "Assign_AML_Subtype" },
    "Delay_3":  { "type": "Delay", "exact": { "quantity": 3,  "unit": "years" }, "direct_transition": "Assign_AML_Subtype" },
    "Delay_4":  { "type": "Delay", "exact": { "quantity": 4,  "unit": "years" }, "direct_transition": "Assign_AML_Subtype" },
    "Delay_5":  { "type": "Delay", "exact": { "quantity": 5,  "unit": "years" }, "direct_transition": "Assign_AML_Subtype" },
    "Delay_6":  { "type": "Delay", "exact": { "quantity": 6,  "unit": "years" }, "direct_transition": "Assign_AML_Subtype" },
    "Delay_7":  { "type": "Delay", "exact": { "quantity": 7,  "unit": "years" }, "direct_transition": "Assign_AML_Subtype" },
    "Delay_8":  { "type": "Delay", "exact": { "quantity": 8,  "unit": "years" }, "direct_transition": "Assign_AML_Subtype" },
    "Delay_9":  { "type": "Delay", "exact": { "quantity": 9,  "unit": "years" }, "direct_transition": "Assign_AML_Subtype" },
    "Delay_10": { "type": "Delay", "exact": { "quantity": 10, "unit": "years" }, "direct_transition": "Assign_AML_Subtype" },
    "Delay_11": { "type": "Delay", "exact": { "quantity": 11, "unit": "years" }, "direct_transition": "Assign_AML_Subtype" },
    "Delay_12": { "type": "Delay", "exact": { "quantity": 12, "unit": "years" }, "direct_transition": "Assign_AML_Subtype" },
    "Delay_13": { "type": "Delay", "exact": { "quantity": 13, "unit": "years" }, "direct_transition": "Assign_AML_Subtype" },
    "Delay_14": { "type": "Delay", "exact": { "quantity": 14, "unit": "years" }, "direct_transition": "Assign_AML_Subtype" },
    "Delay_15": { "type": "Delay", "exact": { "quantity": 15, "unit": "years" }, "direct_transition": "Assign_AML_Subtype" },
    "Delay_16": { "type": "Delay", "exact": { "quantity": 16, "unit": "years" }, "direct_transition": "Assign_AML_Subtype" },
    "Delay_17": { "type": "Delay", "exact": { "quantity": 17, "unit": "years" }, "direct_transition": "Assign_AML_Subtype" },
    "Delay_18": { "type": "Delay", "exact": { "quantity": 18, "unit": "years" }, "direct_transition": "Assign_AML_Subtype" },
    "Delay_19": { "type": "Delay", "exact": { "quantity": 19, "unit": "years" }, "direct_transition": "Assign_AML_Subtype" },
    "Delay_20": { "type": "Delay", "exact": { "quantity": 20, "unit": "years" }, "direct_transition": "Assign_AML_Subtype" },
    "Delay_21": { "type": "Delay", "exact": { "quantity": 21, "unit": "years" }, "direct_transition": "Assign_AML_Subtype" },

    "Assign_AML_Subtype": {
      "type": "Simple",
      "remarks": [
        "Distribute patients across six clinically representative AML subtypes.",
        "Proportions reflect approximate published incidence fractions."
      ],
      "distributed_transition": [
        { "transition": "Set_Subtype_NPM1",       "distribution": 0.27 },
        { "transition": "Set_Subtype_FLT3_ITD",   "distribution": 0.25 },
        { "transition": "Set_Subtype_APL",         "distribution": 0.10 },
        { "transition": "Set_Subtype_CBF",         "distribution": 0.08 },
        { "transition": "Set_Subtype_IDH",         "distribution": 0.10 },
        { "transition": "Set_Subtype_TP53_MDS",    "distribution": 0.20 }
      ]
    },

    "Set_Subtype_NPM1": {
      "type": "SetAttribute",
      "attribute": "aml_subtype",
      "value": "AML_NPM1",
      "direct_transition": "Set_ELN_Risk_Favorable"
    },
    "Set_Subtype_FLT3_ITD": {
      "type": "SetAttribute",
      "attribute": "aml_subtype",
      "value": "AML_FLT3_ITD",
      "direct_transition": "Set_ELN_Risk_Intermediate"
    },
    "Set_Subtype_APL": {
      "type": "SetAttribute",
      "attribute": "aml_subtype",
      "value": "APL_PML_RARA",
      "direct_transition": "Set_ELN_Risk_Favorable"
    },
    "Set_Subtype_CBF": {
      "type": "SetAttribute",
      "attribute": "aml_subtype",
      "value": "AML_CBF_RUNX1_RUNX1T1",
      "direct_transition": "Set_ELN_Risk_Favorable"
    },
    "Set_Subtype_IDH": {
      "type": "SetAttribute",
      "attribute": "aml_subtype",
      "value": "AML_IDH",
      "direct_transition": "Set_ELN_Risk_Intermediate"
    },
    "Set_Subtype_TP53_MDS": {
      "type": "SetAttribute",
      "attribute": "aml_subtype",
      "value": "AML_TP53_MDS",
      "direct_transition": "Set_ELN_Risk_Adverse"
    },

    "Set_ELN_Risk_Favorable": {
      "type": "SetAttribute",
      "attribute": "aml_eln_risk",
      "value": "Favorable",
      "direct_transition": "Subtype_Condition_Branch"
    },
    "Set_ELN_Risk_Intermediate": {
      "type": "SetAttribute",
      "attribute": "aml_eln_risk",
      "value": "Intermediate",
      "direct_transition": "Subtype_Condition_Branch"
    },
    "Set_ELN_Risk_Adverse": {
      "type": "SetAttribute",
      "attribute": "aml_eln_risk",
      "value": "Adverse",
      "direct_transition": "Subtype_Condition_Branch"
    },

    "Subtype_Condition_Branch": {
      "type": "Simple",
      "remarks": [
        "Record the specific AML subtype as a ConditionOnset so it appears in conditions.csv.",
        "Each subtype has a distinct SNOMED-CT code from the AML/hematology hierarchy."
      ],
      "complex_transition": [
        {
          "condition": {
            "condition_type": "Attribute",
            "attribute": "aml_subtype",
            "operator": "==",
            "value": "AML_NPM1"
          },
          "transition": "Subtype_NPM1_Onset"
        },
        {
          "condition": {
            "condition_type": "Attribute",
            "attribute": "aml_subtype",
            "operator": "==",
            "value": "AML_FLT3_ITD"
          },
          "transition": "Subtype_FLT3_Onset"
        },
        {
          "condition": {
            "condition_type": "Attribute",
            "attribute": "aml_subtype",
            "operator": "==",
            "value": "APL_PML_RARA"
          },
          "transition": "Subtype_APL_Onset"
        },
        {
          "condition": {
            "condition_type": "Attribute",
            "attribute": "aml_subtype",
            "operator": "==",
            "value": "AML_CBF_RUNX1_RUNX1T1"
          },
          "transition": "Subtype_CBF_Onset"
        },
        {
          "condition": {
            "condition_type": "Attribute",
            "attribute": "aml_subtype",
            "operator": "==",
            "value": "AML_IDH"
          },
          "transition": "Subtype_IDH_Onset"
        },
        {
          "transition": "Subtype_TP53_MDS_Onset"
        }
      ]
    },

    "Subtype_NPM1_Onset": {
      "type": "ConditionOnset",
      "assign_to_attribute": "aml_subtype_condition",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "413448000",
          "display": "Acute myeloid leukemia with NPM1 mutation (disorder)"
        }
      ],
      "direct_transition": "AML_Condition_Onset"
    },
    "Subtype_FLT3_Onset": {
      "type": "ConditionOnset",
      "assign_to_attribute": "aml_subtype_condition",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "413449008",
          "display": "Acute myeloid leukemia with FLT3 mutation (disorder)"
        }
      ],
      "direct_transition": "AML_Condition_Onset"
    },
    "Subtype_APL_Onset": {
      "type": "ConditionOnset",
      "assign_to_attribute": "aml_subtype_condition",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "413441009",
          "display": "Acute promyelocytic leukemia (disorder)"
        }
      ],
      "direct_transition": "AML_Condition_Onset"
    },
    "Subtype_CBF_Onset": {
      "type": "ConditionOnset",
      "assign_to_attribute": "aml_subtype_condition",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "413442002",
          "display": "Acute myeloid leukemia with t(8;21)(q22;q22) (disorder)"
        }
      ],
      "direct_transition": "AML_Condition_Onset"
    },
    "Subtype_IDH_Onset": {
      "type": "ConditionOnset",
      "assign_to_attribute": "aml_subtype_condition",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "1162864003",
          "display": "Acute myeloid leukemia with IDH1 mutation (disorder)"
        }
      ],
      "direct_transition": "AML_Condition_Onset"
    },
    "Subtype_TP53_MDS_Onset": {
      "type": "ConditionOnset",
      "assign_to_attribute": "aml_subtype_condition",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "763512003",
          "display": "Acute myeloid leukemia with myelodysplasia-related changes (disorder)"
        }
      ],
      "direct_transition": "AML_Condition_Onset"
    },

    "AML_Condition_Onset": {
      "type": "ConditionOnset",
      "assign_to_attribute": "aml_condition",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "91861009",
          "display": "Acute myeloid leukemia (disorder)"
        }
      ],
      "direct_transition": "Inpatient_Encounter"
    },

    "Inpatient_Encounter": {
      "type": "Encounter",
      "encounter_class": "inpatient",
      "reason": "AML_Condition_Onset",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "185347001",
          "display": "Encounter for problem (procedure)"
        }
      ],
      "direct_transition": "CBC_WBC"
    },

    "CBC_WBC": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "10*3/uL",
      "codes": [
        {
          "system": "LOINC",
          "code": "6690-2",
          "display": "Leukocytes [#/volume] in Blood by Automated count"
        }
      ],
      "range": { "low": 3.0, "high": 120.0 },
      "direct_transition": "CBC_Hemoglobin"
    },
    "CBC_Hemoglobin": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "g/dL",
      "codes": [
        {
          "system": "LOINC",
          "code": "718-7",
          "display": "Hemoglobin [Mass/volume] in Blood"
        }
      ],
      "range": { "low": 6.0, "high": 10.5 },
      "direct_transition": "CBC_Platelets"
    },
    "CBC_Platelets": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "10*3/uL",
      "codes": [
        {
          "system": "LOINC",
          "code": "777-3",
          "display": "Platelets [#/volume] in Blood by Automated count"
        }
      ],
      "range": { "low": 10.0, "high": 100.0 },
      "direct_transition": "CBC_ANC"
    },
    "CBC_ANC": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "10*3/uL",
      "codes": [
        {
          "system": "LOINC",
          "code": "751-8",
          "display": "Neutrophils [#/volume] in Blood by Automated count"
        }
      ],
      "range": { "low": 0.1, "high": 1.0 },
      "direct_transition": "Peripheral_Blood_Blasts"
    },
    "Peripheral_Blood_Blasts": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "%",
      "codes": [
        {
          "system": "LOINC",
          "code": "709-6",
          "display": "Blasts/100 leukocytes in Blood by Manual count"
        }
      ],
      "range": { "low": 20.0, "high": 80.0 },
      "direct_transition": "LDH_Chemistry"
    },
    "LDH_Chemistry": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "U/L",
      "codes": [
        {
          "system": "LOINC",
          "code": "14804-9",
          "display": "Lactate dehydrogenase [Enzymatic activity/volume] in Serum or Plasma"
        }
      ],
      "range": { "low": 300.0, "high": 2000.0 },
      "direct_transition": "Creatinine_Chemistry"
    },
    "Creatinine_Chemistry": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "mg/dL",
      "codes": [
        {
          "system": "LOINC",
          "code": "2160-0",
          "display": "Creatinine [Mass/volume] in Serum or Plasma"
        }
      ],
      "range": { "low": 0.4, "high": 1.2 },
      "direct_transition": "Uric_Acid_Chemistry"
    },
    "Uric_Acid_Chemistry": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "mg/dL",
      "codes": [
        {
          "system": "LOINC",
          "code": "3084-1",
          "display": "Urate [Mass/volume] in Serum or Plasma"
        }
      ],
      "range": { "low": 4.0, "high": 12.0 },
      "direct_transition": "Bone_Marrow_Biopsy"
    },

    "Bone_Marrow_Biopsy": {
      "type": "Procedure",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "86273004",
          "display": "Biopsy of bone marrow"
        }
      ],
      "duration": { "low": 30, "high": 60, "unit": "minutes" },
      "reason": "AML_Condition_Onset",
      "direct_transition": "BM_Blast_Percentage"
    },
    "BM_Blast_Percentage": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "%",
      "codes": [
        {
          "system": "LOINC",
          "code": "26464-8",
          "display": "Blasts/100 cells in Bone marrow"
        }
      ],
      "range": { "low": 20.0, "high": 90.0 },
      "direct_transition": "Karyotype_Procedure"
    },

    "Karyotype_Procedure": {
      "type": "Procedure",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "734877004",
          "display": "Karyotyping of bone marrow specimen (procedure)"
        }
      ],
      "duration": { "low": 60, "high": 120, "unit": "minutes" },
      "reason": "AML_Condition_Onset",
      "direct_transition": "FISH_Procedure"
    },
    "FISH_Procedure": {
      "type": "Procedure",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "445484009",
          "display": "Fluorescence in situ hybridization (procedure)"
        }
      ],
      "duration": { "low": 30, "high": 60, "unit": "minutes" },
      "reason": "AML_Condition_Onset",
      "direct_transition": "NGS_Panel_Procedure"
    },
    "NGS_Panel_Procedure": {
      "type": "Procedure",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "1186936003",
          "display": "Next generation sequencing panel testing (procedure)"
        }
      ],
      "duration": { "low": 60, "high": 120, "unit": "minutes" },
      "reason": "AML_Condition_Onset",
      "direct_transition": "Subtype_Assay_Branch"
    },

    "Subtype_Assay_Branch": {
      "type": "Simple",
      "remarks": [
        "Branch to subtype-specific confirmatory assays and genomic capture.",
        "RT-PCR for fusion subtypes (APL, CBF); molecular observations for point-mutation subtypes."
      ],
      "complex_transition": [
        {
          "condition": {
            "condition_type": "Attribute",
            "attribute": "aml_subtype",
            "operator": "==",
            "value": "APL_PML_RARA"
          },
          "transition": "RT_PCR_PML_RARA"
        },
        {
          "condition": {
            "condition_type": "Attribute",
            "attribute": "aml_subtype",
            "operator": "==",
            "value": "AML_CBF_RUNX1_RUNX1T1"
          },
          "transition": "RT_PCR_RUNX1_RUNX1T1"
        },
        {
          "condition": {
            "condition_type": "Attribute",
            "attribute": "aml_subtype",
            "operator": "==",
            "value": "AML_FLT3_ITD"
          },
          "transition": "FLT3_ITD_Observation"
        },
        {
          "condition": {
            "condition_type": "Attribute",
            "attribute": "aml_subtype",
            "operator": "==",
            "value": "AML_NPM1"
          },
          "transition": "NPM1_Mutation_Observation"
        },
        {
          "condition": {
            "condition_type": "Attribute",
            "attribute": "aml_subtype",
            "operator": "==",
            "value": "AML_IDH"
          },
          "transition": "IDH_Mutation_Observation"
        },
        {
          "transition": "Genomics_TP53_MDS"
        }
      ]
    },

    "RT_PCR_PML_RARA": {
      "type": "Procedure",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "726654001",
          "display": "Reverse transcription polymerase chain reaction (procedure)"
        }
      ],
      "duration": { "low": 30, "high": 60, "unit": "minutes" },
      "reason": "AML_Condition_Onset",
      "direct_transition": "PML_RARA_Fusion_Observation"
    },
    "PML_RARA_Fusion_Observation": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "{Qualitative}",
      "codes": [
        {
          "system": "LOINC",
          "code": "42797-5",
          "display": "PML gene rearrangements [Presence] in Blood or Tissue by FISH"
        }
      ],
      "value_code": {
        "system": "SNOMED-CT",
        "code": "10828004",
        "display": "Positive (qualifier value)"
      },
      "direct_transition": "Genomics_APL"
    },

    "RT_PCR_RUNX1_RUNX1T1": {
      "type": "Procedure",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "726654001",
          "display": "Reverse transcription polymerase chain reaction (procedure)"
        }
      ],
      "duration": { "low": 30, "high": 60, "unit": "minutes" },
      "reason": "AML_Condition_Onset",
      "direct_transition": "RUNX1_RUNX1T1_Fusion_Observation"
    },
    "RUNX1_RUNX1T1_Fusion_Observation": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "{Qualitative}",
      "codes": [
        {
          "system": "LOINC",
          "code": "53007-3",
          "display": "RUNX1T1 gene rearrangements [Presence] in Blood or Tissue"
        }
      ],
      "value_code": {
        "system": "SNOMED-CT",
        "code": "10828004",
        "display": "Positive (qualifier value)"
      },
      "direct_transition": "Genomics_CBF"
    },

    "FLT3_ITD_Observation": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "{Qualitative}",
      "codes": [
        {
          "system": "LOINC",
          "code": "85176-4",
          "display": "FLT3 gene internal tandem duplication [Presence] in Blood or Tissue by Molecular genetics method"
        }
      ],
      "value_code": {
        "system": "SNOMED-CT",
        "code": "10828004",
        "display": "Positive (qualifier value)"
      },
      "direct_transition": "Genomics_FLT3_ITD"
    },

    "NPM1_Mutation_Observation": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "{Qualitative}",
      "codes": [
        {
          "system": "LOINC",
          "code": "89266-3",
          "display": "NPM1 gene mutation analysis in Blood or Tissue by Molecular genetics method"
        }
      ],
      "value_code": {
        "system": "SNOMED-CT",
        "code": "10828004",
        "display": "Positive (qualifier value)"
      },
      "direct_transition": "Genomics_NPM1"
    },

    "IDH_Mutation_Observation": {
