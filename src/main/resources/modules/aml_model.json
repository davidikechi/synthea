      "ontology": {
        "system": "LOINC",
        "code": "751-8",
        "display": "Neutrophils [#/volume] in Blood by Automated count"
      },
      "unit": "10*3/uL",
      "referenceRange": {
        "low": 1.5,
        "high": 8.0
      },
      "clinicalUse": "Infection risk stratification and chemotherapy supportive care"
    },
    {
      "name": "Platelet count",
      "category": "hematology",
      "ontology": {
        "system": "LOINC",
        "code": "777-3",
        "display": "Platelets [#/volume] in Blood by Automated count"
      },
      "unit": "10*3/uL"
    },
    {
      "name": "Hemoglobin",
      "category": "hematology",
      "ontology": {
        "system": "LOINC",
        "code": "718-7",
        "display": "Hemoglobin [Mass/volume] in Blood"
      },
      "unit": "g/dL"
    },
    {
      "name": "Lactate dehydrogenase",
      "category": "chemistry",
      "ontology": {
        "system": "LOINC",
        "code": "14804-9",
        "display": "Lactate dehydrogenase [Enzymatic activity/volume] in Serum or Plasma"
      },
      "unit": "U/L"
    },
    {
      "name": "Creatinine",
      "category": "chemistry",
      "ontology": {
        "system": "LOINC",
        "code": "2160-0",
        "display": "Creatinine [Mass/volume] in Serum or Plasma"
      },
      "unit": "mg/dL"
    }
  ],
  "treatments": {
    "induction": [
      {
        "name": "7+3 induction chemotherapy",
        "regimen": [
          "Cytarabine continuous infusion x7 days",
          "Anthracycline (daunorubicin or idarubicin) x3 days"
        ],
        "ontology": {
          "system": "NCIT",
          "code": "C63446",
          "display": "Induction Therapy"
        }
      },
      {
        "name": "Venetoclax + hypomethylating agent",
        "regimen": [
          "Venetoclax",
          "Azacitidine or decitabine"
        ],
        "useCase": "Older/unfit patients"
      }
    ],
    "targeted": [
      {
        "name": "Midostaurin",
        "target": "FLT3",
        "ontology": {
          "system": "RxNorm",
          "code": "1111495",
          "display": "midostaurin"
        }
      },
      {
        "name": "Gilteritinib",
        "target": "FLT3",
        "ontology": {
          "system": "RxNorm",
          "code": "2373702",
          "display": "gilteritinib"
        }
      },
      {
        "name": "Ivosidenib",
        "target": "IDH1",
        "ontology": {
          "system": "RxNorm",
          "code": "1792776",
          "display": "ivosidenib"
        }
      },
      {
        "name": "Enasidenib",
        "target": "IDH2",
        "ontology": {
          "system": "RxNorm",
          "code": "1923619",
          "display": "enasidenib"
        }
      },
      {
        "name": "Gemtuzumab ozogamicin",
        "target": "CD33",
        "ontology": {
          "system": "RxNorm",
          "code": "1293705",
          "display": "gemtuzumab ozogamicin"
        }
      }
    ],
    "aplSpecific": [
      {
        "name": "All-trans retinoic acid (ATRA)",
        "ontology": {
          "system": "RxNorm",
          "code": "723",
          "display": "tretinoin"
        }
      },
      {
        "name": "Arsenic trioxide",
        "ontology": {
          "system": "RxNorm",
          "code": "17419",
          "display": "arsenic trioxide"
        }
      }
    ],
    "consolidationAndDefinitive": [
      {
        "name": "High-dose cytarabine consolidation"
      },
      {
        "name": "Allogeneic hematopoietic stem cell transplantation",
        "ontology": {
          "system": "SNOMED-CT",
          "code": "423003",
          "display": "Allogeneic bone marrow transplant"
        }
      }
    ],
    "supportiveCare": [
      {
        "name": "Antimicrobial prophylaxis",
        "examples": [
          "Levofloxacin",
          "Acyclovir",
          "Posaconazole"
        ]
      },
      {
        "name": "Tumor lysis prophylaxis",
        "examples": [
          "Allopurinol",
          "Rasburicase",
          "Aggressive hydration"
        ]
      },
      {
        "name": "Transfusion support",
        "examples": [
          "Packed red blood cells",
          "Platelets"
        ]
      }
    ]
  },
  "riskStratification": {
    "framework": "ELN-2022",
    "groups": [
      {
        "label": "Favorable",
        "examples": [
          "NPM1-mutated without FLT3-ITD high burden",
          "Core-binding factor AML"
        ]
      },
      {
        "label": "Intermediate",
        "examples": [
          "Genetic profiles not in favorable or adverse"
        ]
      },
      {
        "label": "Adverse",
        "examples": [
          "TP53 mutation",
          "Complex karyotype",
          "Certain myelodysplasia-related gene mutations"
        ]
      }
    ]
  },
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Assign_AML_Subtype"
    },

    "Assign_AML_Subtype": {
      "type": "Simple",
      "distributed_transition": [
        {"transition": "Set_Subtype_FLT3_ITD",       "distribution": 0.30},
        {"transition": "Set_Subtype_NPM1",            "distribution": 0.25},
        {"transition": "Set_Subtype_APL",             "distribution": 0.15},
        {"transition": "Set_Subtype_MDS_Related",     "distribution": 0.20},
        {"transition": "Set_Subtype_Therapy_Related", "distribution": 0.10}
      ]
    },

    "Set_Subtype_FLT3_ITD": {
      "type": "SetAttribute",
      "attribute": "aml_subtype",
      "value": "AML_FLT3_ITD",
      "direct_transition": "AML_Condition_Onset"
    },
    "Set_Subtype_NPM1": {
      "type": "SetAttribute",
      "attribute": "aml_subtype",
      "value": "AML_NPM1",
      "direct_transition": "AML_Condition_Onset"
    },
    "Set_Subtype_APL": {
      "type": "SetAttribute",
      "attribute": "aml_subtype",
      "value": "APL_PML_RARA",
      "direct_transition": "AML_Condition_Onset"
    },
    "Set_Subtype_MDS_Related": {
      "type": "SetAttribute",
      "attribute": "aml_subtype",
      "value": "AML_MDS_Related",
      "direct_transition": "AML_Condition_Onset"
    },
    "Set_Subtype_Therapy_Related": {
      "type": "SetAttribute",
      "attribute": "aml_subtype",
      "value": "AML_Therapy_Related",
      "direct_transition": "AML_Condition_Onset"
    },

    "AML_Condition_Onset": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "91857003",
          "display": "Acute myeloid leukemia (disorder)"
        }
      ],
      "direct_transition": "Diagnosis_Inpatient_Encounter"
    },

    "Diagnosis_Inpatient_Encounter": {
      "type": "Encounter",
      "encounter_class": "inpatient",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "183807002",
          "display": "Inpatient stay"
        }
      ],
      "direct_transition": "Bone_Marrow_Blast_Pct"
    },

    "Bone_Marrow_Blast_Pct": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "%",
      "codes": [
        {
          "system": "LOINC",
          "code": "26464-8",
          "display": "Blasts/100 cells in Bone marrow"
        }
      ],
      "range": {"low": 20, "high": 95},
      "direct_transition": "ANC_Lab"
    },

    "ANC_Lab": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "10*3/uL",
      "codes": [
        {
          "system": "LOINC",
          "code": "751-8",
          "display": "Neutrophils [#/volume] in Blood by Automated count"
        }
      ],
      "range": {"low": 0.2, "high": 1.5},
      "direct_transition": "Platelet_Lab"
    },

    "Platelet_Lab": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "10*3/uL",
      "codes": [
        {
          "system": "LOINC",
          "code": "777-3",
          "display": "Platelets [#/volume] in Blood by Automated count"
        }
      ],
      "range": {"low": 20, "high": 80},
      "direct_transition": "Hemoglobin_Lab"
    },

    "Hemoglobin_Lab": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "g/dL",
      "codes": [
        {
          "system": "LOINC",
          "code": "718-7",
          "display": "Hemoglobin [Mass/volume] in Blood"
        }
      ],
      "range": {"low": 7.0, "high": 10.0},
      "direct_transition": "Bone_Marrow_Biopsy"
    },

    "Bone_Marrow_Biopsy": {
      "type": "Procedure",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "86273004",
          "display": "Biopsy of bone marrow"
        }
      ],
      "direct_transition": "Genomics_Branch"
    },

    "Genomics_Branch": {
      "type": "Simple",
      "complex_transition": [
        {
          "condition": {
            "condition_type": "Attribute",
            "attribute": "aml_subtype",
            "operator": "=",
            "value": "AML_FLT3_ITD"
          },
          "transition": "Capture_Genomics_FLT3"
        },
        {
          "condition": {
            "condition_type": "Attribute",
            "attribute": "aml_subtype",
            "operator": "=",
            "value": "AML_NPM1"
          },
          "transition": "Capture_Genomics_NPM1"
        },
        {
          "condition": {
            "condition_type": "Attribute",
            "attribute": "aml_subtype",
            "operator": "=",
            "value": "APL_PML_RARA"
          },
          "transition": "Capture_Genomics_APL"
        },
        {
          "condition": {
            "condition_type": "Attribute",
            "attribute": "aml_subtype",
            "operator": "=",
            "value": "AML_MDS_Related"
          },
          "transition": "Capture_Genomics_MDS"
        },
        {
          "transition": "Capture_Genomics_Therapy"
        }
      ]
    },

    "Capture_Genomics_FLT3": {
      "type": "SetAttribute",
      "attribute": "genomics_alterations",
      "value": [
        {
          "method_genomics": "NGS",
          "source_genomics": "Bone marrow",
          "alteration_type": "ITD",
          "gene": "FLT3",
          "alteration_status": "Pathogenic",
          "chromosome": "13",
          "hgvs_coding": "c.1770_1942dup",
          "genome_version": "GRCh38",
          "vaf": 0.48
        }
      ],
      "direct_transition": "Give_Cytarabine_FLT3"
    },

    "Capture_Genomics_NPM1": {
      "type": "SetAttribute",
      "attribute": "genomics_alterations",
      "value": [
        {
          "method_genomics": "NGS",
          "source_genomics": "Bone marrow",
          "alteration_type": "indel",
          "gene": "NPM1",
          "alteration_status": "Pathogenic",
          "chromosome": "5",
          "hgvs_coding": "c.860_863dup",
          "hgvs_protein": "p.Trp288CysfsTer12",
          "genome_version": "GRCh38",
          "vaf": 0.45
        }
      ],
      "direct_transition": "Give_Daunorubicin_NPM1"
    },

    "Capture_Genomics_APL": {
      "type": "SetAttribute",
      "attribute": "genomics_alterations",
      "value": [
        {
          "method_genomics": "RT-PCR",
          "source_genomics": "Bone marrow",
          "alteration_type": "fusion",
          "gene": "PML",
          "fusion": "PML::RARA",
          "structural_event": "t(15;17)(q24.1;q21.2)",
          "alteration_status": "Pathogenic",
          "genome_version": "GRCh38",
          "vaf": 0.52
        }
      ],
      "direct_transition": "Give_ATRA"
    },

    "Capture_Genomics_MDS": {
      "type": "SetAttribute",
      "attribute": "genomics_alterations",
      "value": [
        {
          "method_genomics": "NGS",
          "source_genomics": "Bone marrow",
          "alteration_type": "SNV",
          "gene": "ASXL1",
          "alteration_status": "Pathogenic",
          "chromosome": "20",
          "hgvs_coding": "c.1934dupG",
          "hgvs_protein": "p.Gly646TrpfsTer12",
          "genome_version": "GRCh38",
          "vaf": 0.38
        }
      ],
      "direct_transition": "Give_Venetoclax"
    },

    "Capture_Genomics_Therapy": {
      "type": "SetAttribute",
      "attribute": "genomics_alterations",
      "value": [
        {
          "method_genomics": "NGS",
          "source_genomics": "Bone marrow",
          "alteration_type": "SNV",
          "gene": "TP53",
          "alteration_status": "Pathogenic",
          "chromosome": "17",
          "hgvs_coding": "c.817C>T",
          "hgvs_protein": "p.Arg273Cys",
          "genome_version": "GRCh38",
          "vaf": 0.41
        }
      ],
      "direct_transition": "Give_Cytarabine_Therapy"
    },

    "Give_Cytarabine_FLT3": {
      "type": "MedicationOrder",
      "codes": [
        {"system": "RxNorm", "code": "197361", "display": "cytarabine 100 MG Injection"}
      ],
      "reason": "AML_FLT3_ITD",
      "direct_transition": "Give_Midostaurin"
    },
    "Give_Midostaurin": {
      "type": "MedicationOrder",
      "codes": [
        {"system": "RxNorm", "code": "1111495", "display": "midostaurin 25 MG Oral Capsule"}
      ],
      "reason": "AML_FLT3_ITD",
      "direct_transition": "End_Encounter"
    },

    "Give_Daunorubicin_NPM1": {
      "type": "MedicationOrder",
      "codes": [
        {"system": "RxNorm", "code": "197519", "display": "daunorubicin 5 MG/ML Injection"}
      ],
      "reason": "AML_NPM1",
      "direct_transition": "Give_Cytarabine_NPM1"
    },
    "Give_Cytarabine_NPM1": {
      "type": "MedicationOrder",
      "codes": [
        {"system": "RxNorm", "code": "197361", "display": "cytarabine 100 MG Injection"}
      ],
      "reason": "AML_NPM1",
      "direct_transition": "End_Encounter"
    },

    "Give_ATRA": {
      "type": "MedicationOrder",
      "codes": [
        {"system": "RxNorm", "code": "723", "display": "tretinoin 10 MG Oral Capsule"}
      ],
      "reason": "APL_PML_RARA",
      "direct_transition": "Give_Arsenic_Trioxide"
    },
    "Give_Arsenic_Trioxide": {
      "type": "MedicationOrder",
      "codes": [
        {"system": "RxNorm", "code": "17419", "display": "arsenic trioxide 1 MG/ML Injection"}
      ],
      "reason": "APL_PML_RARA",
      "direct_transition": "End_Encounter"
    },

    "Give_Venetoclax": {
      "type": "MedicationOrder",
