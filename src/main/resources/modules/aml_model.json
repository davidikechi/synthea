{
  "resourceType": "DiseaseKnowledgeModel",
  "id": "acute-myeloid-leukemia-model-v1",
  "name": "AML Disease Model",
  "gmf_version": 2,
  "version": "1.0.0",
  "status": "active",
  "description": "Executable AML module with subtype branching, clinical encounters, lab observations, bone marrow biopsy, genomic alterations, and subtype-guided treatment. Use with -m aml_model to generate conditions, observations, procedures, medications, and genomics CSVs.",
  "ontologies": {
    "disease": [
      {
        "system": "MONDO",
        "code": "MONDO:0018874",
        "display": "acute myeloid leukemia"
      },
      {
        "system": "NCIT",
        "code": "C3171",
        "display": "Acute Myeloid Leukemia"
      },
      {
        "system": "SNOMED-CT",
        "code": "91857003",
        "display": "Acute myeloid leukemia (disorder)"
      },
      {
        "system": "ICD-10-CM",
        "code": "C92.00",
        "display": "Acute myeloblastic leukemia, not having achieved remission"
      }
    ],
    "classificationSystems": [
      {
        "system": "WHO-HAEM5",
        "display": "WHO Classification of Haematolymphoid Tumours, 5th edition"
      },
      {
        "system": "ICC",
        "display": "International Consensus Classification"
      },
      {
        "system": "ELN-2022",
        "display": "European LeukemiaNet genetic risk classification"
      }
    ]
  },
  "subtypes": [
    {
      "id": "aml-defining-genetic-abnormalities",
      "label": "AML with defining genetic abnormalities",
      "category": "genetically_defined",
      "examples": [
        {
          "name": "AML with RUNX1::RUNX1T1 fusion",
          "ontology": {
            "system": "NCIT",
            "code": "C129785"
          },
          "definingFindings": [
            "t(8;21)(q22;q22.1)",
            "RUNX1::RUNX1T1 fusion"
          ]
        },
        {
          "name": "AML with CBFB::MYH11 fusion",
          "ontology": {
            "system": "NCIT",
            "code": "C37214"
          },
          "definingFindings": [
            "inv(16)(p13.1q22) or t(16;16)",
            "CBFB::MYH11 fusion"
          ]
        },
        {
          "name": "Acute promyelocytic leukemia",
          "ontology": {
            "system": "NCIT",
            "code": "C3439"
          },
          "definingFindings": [
            "PML::RARA fusion",
            "t(15;17)(q24.1;q21.2)"
          ]
        },
        {
          "name": "AML with mutated NPM1",
          "ontology": {
            "system": "NCIT",
            "code": "C129786"
          },
          "definingFindings": [
            "NPM1 pathogenic mutation"
          ]
        },
        {
          "name": "AML with bZIP in-frame mutated CEBPA",
          "ontology": {
            "system": "NCIT",
            "code": "C168785"
          },
          "definingFindings": [
            "CEBPA bZIP in-frame mutation"
          ]
        }
      ]
    },
    {
      "id": "aml-myelodysplasia-related",
      "label": "AML, myelodysplasia related",
      "category": "secondary",
      "examples": [
        {
          "name": "AML with myelodysplasia-related gene mutations",
          "commonGenes": [
            "ASXL1",
            "BCOR",
            "EZH2",
            "RUNX1",
            "SF3B1",
            "SRSF2",
            "STAG2",
            "U2AF1",
            "ZRSR2"
          ]
        },
        {
          "name": "AML with myelodysplasia-related cytogenetic abnormalities"
        }
      ]
    },
    {
      "id": "therapy-related-aml",
      "label": "Therapy-related AML",
      "category": "secondary",
      "examples": [
        {
          "name": "AML post-alkylating agent exposure"
        },
        {
          "name": "AML post-topoisomerase-II inhibitor exposure"
        }
      ]
    }
  ],
  "genomicMethodsAndAssays": [
    {
      "name": "Conventional karyotype",
      "purpose": "Detect balanced/unbalanced chromosomal abnormalities",
      "ontology": {
        "system": "NCIT",
        "code": "C111137",
        "display": "Karyotyping"
      },
      "outputExamples": [
        "t(8;21)",
        "inv(16)",
        "complex karyotype"
      ]
    },
    {
      "name": "Fluorescence in situ hybridization (FISH)",
      "purpose": "Rapid targeted fusion/structural variant confirmation",
      "ontology": {
        "system": "NCIT",
        "code": "C17356",
        "display": "Fluorescence In Situ Hybridization"
      }
    },
    {
      "name": "RT-PCR / qPCR fusion testing",
      "purpose": "Detect recurrent fusion transcripts and molecular monitoring",
      "ontology": {
        "system": "NCIT",
        "code": "C18189",
        "display": "Polymerase Chain Reaction"
      },
      "targets": [
        "PML::RARA",
        "RUNX1::RUNX1T1",
        "CBFB::MYH11"
      ]
    },
    {
      "name": "Targeted DNA NGS panel",
      "purpose": "Identify pathogenic SNV/indel variants for diagnosis/prognosis/therapy",
      "ontology": {
        "system": "NCIT",
        "code": "C157598",
        "display": "Next Generation Sequencing"
      },
      "commonGenes": [
        "FLT3",
        "NPM1",
        "IDH1",
        "IDH2",
        "TP53",
        "RUNX1",
        "ASXL1",
        "DNMT3A",
        "TET2",
        "KIT",
        "NRAS",
        "KRAS"
      ]
    },
    {
      "name": "RNA sequencing",
      "purpose": "Fusion discovery and expression profiling",
      "ontology": {
        "system": "NCIT",
        "code": "C116071",
        "display": "RNA Sequencing"
      }
    },
    {
      "name": "MRD flow cytometry",
      "purpose": "Quantify measurable residual disease using leukemia-associated immunophenotypes",
      "ontology": {
        "system": "NCIT",
        "code": "C18195",
        "display": "Flow Cytometry"
      },
      "resultUnit": "% cells"
    }
  ],
  "conditions": [
