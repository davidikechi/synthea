        "display": "Disseminated intravascular coagulation (disorder)"
      }
    }
  ],
  "observations": [
    {
      "name": "Bone marrow blast percentage",
      "type": "morphology",
      "ontology": {
        "system": "LOINC",
        "code": "26464-8",
        "display": "Blasts/100 cells in Bone marrow"
      },
      "interpretation": "AML is typically diagnosed at >=20% blasts, except in defined genetic entities"
    },
    {
      "name": "Peripheral blood blast percentage",
      "type": "morphology",
      "ontology": {
        "system": "LOINC",
        "code": "709-6",
        "display": "Blasts/100 leukocytes in Blood by Manual count"
      }
    },
    {
      "name": "FLT3 internal tandem duplication status",
      "type": "molecular",
      "ontology": {
        "system": "LOINC",
        "code": "85176-4",
        "display": "FLT3 gene internal tandem duplication [Presence] in Blood or Tissue by Molecular genetics method"
      }
    },
    {
      "name": "NPM1 mutation status",
      "type": "molecular",
      "ontology": {
        "system": "LOINC",
        "code": "89266-3",
        "display": "NPM1 gene mutation analysis in Blood or Tissue by Molecular genetics method"
      }
    },
    {
      "name": "MRD level by flow",
      "type": "response_assessment",
      "ontology": {
        "system": "NCIT",
        "code": "C122229",
        "display": "Measurable Residual Disease"
      }
    }
  ],
  "measurements": [
    {
      "name": "Absolute neutrophil count",
